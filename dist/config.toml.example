# Sender configuration (Linux/Hyprland side).
[sender]
receiver_host = "192.168.1.100"
receiver_port = 4242

# Monitor name (from `hyprctl monitors`) and edge to trigger capture.
monitor = "DP-1"
edge = "left"

# evdev device path for keyboard capture. Optional -- if omitted, styx
# auto-detects the first keyboard in /dev/input/by-id/.
# Find yours with: ls /dev/input/by-id/ | grep kbd
# keyboard_device = "/dev/input/by-id/usb-Example_Keyboard-event-kbd"

# Fraction of the sender's monitor height (from the bottom) that maps to
# the receiver's full screen height. 0.5 means the bottom half of the
# sender's monitor maps to the receiver's full height; crossing above
# this zone is blocked. Default: 1.0 (full height, no remapping).
# entry_zone = 0.5

[sender.heartbeat]
active_interval_ms = 1000
idle_interval_ms = 5000
miss_threshold = 3

# Receiver configuration (macOS side).
[receiver]
listen_host = "0.0.0.0"
listen_port = 4242

# The edge of the Mac's display that faces the Linux machine. When the
# cursor hits this edge, control returns to the sender.
# Options: left, right, top, bottom (default: right)
return_edge = "right"
